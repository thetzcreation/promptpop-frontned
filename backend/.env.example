# Copy this file to .env and fill in real values. Never commit the real .env.

# MongoDB connection string.
# For local dev: mongodb://localhost:27017
# For free hosted MongoDB: create a free cluster at https://www.mongodb.com/cloud/atlas
# and use the connection string they give you, e.g.:
# mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_URL="mongodb://localhost:27017"

DB_NAME="promptpop"

# Comma-separated list of allowed origins for CORS.
# For local dev this can stay "*", but for production set it to your real
# frontend URL(s), e.g. "https://yourapp.vercel.app"
CORS_ORIGINS="*"

# Admin token used to access the hidden /admin curation panel.
# REQUIRED before deploying publicly — pick a long random string.
# You can generate one with: python3 -c "import secrets; print(secrets.token_urlsafe(24))"
ADMIN_TOKEN="change-me-to-a-long-random-string"
